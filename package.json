{
  "name": "lunchportalen",
  "private": true,
  "version": "1.0.0",
  "description": "Lunchportalen – Firmalunsj med kontroll, forutsigbarhet og bærekraft",
  "type": "module",

  "scripts": {
    "dev": "next dev",
    "build": "npm run check:admin-copy && next build",
    "start": "next start",

    "lint": "next lint",
    "typecheck": "tsc --noEmit",

    "test": "vitest",
    "test:run": "vitest run",
    "test:tenant": "vitest run tests/tenant-isolation.test.ts",

    "check:admin-copy": "node scripts/check-admin-no-hardcoded-text.mjs",

    "preflight": "npm run typecheck && npm run lint && npm run test:run",
    "push:ok": "npm run preflight && git status --porcelain",

    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:check": "git config core.hooksPath"
  },

  "engines": {
    "node": ">=20.11.0"
  },

  "dependencies": {
    "next": "^15.5.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",

    "@supabase/supabase-js": "^2.47.6",
    "@supabase/ssr": "^0.8.0",

    "@sanity/client": "^7.14.0",
    "@sanity/icons": "^3.7.4",

    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1"
  },

  "devDependencies": {
    "typescript": "5.9.3",

    "@types/node": "^20.12.12",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@types/nodemailer": "^7.0.5",

    "eslint": "^9.8.0",
    "eslint-config-next": "15.5.9",

    "postcss": "^8.5.6",
    "autoprefixer": "^10.4.23",
    "tailwindcss": "^3.4.19",

    "vitest": "^2.1.8",
    "dotenv": "^17.2.3"
  },

  "overrides": {
    "esbuild": "^0.25.0"
  }
}
