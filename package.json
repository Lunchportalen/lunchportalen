{
  "name": "lunchportalen",
  "private": true,
  "version": "1.0.0",
  "description": "Lunchportalen – Firmalunsj med kontroll, forutsigbarhet og bærekraft",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:enterprise": "cross-env RC_MODE=true npm run agents:check && cross-env RC_MODE=true npm run audit:api && cross-env RC_MODE=true npm run audit:repo && cross-env RC_MODE=true npm run check:admin-copy && cross-env RC_MODE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "next lint || node -e \"process.exit(0)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:tenant": "vitest run tests/tenant-isolation.test.ts --config vitest.config.ts",
    "check:admin-copy": "node scripts/check-admin-no-hardcoded-text.mjs",
    "audit:api": "cross-env RC_MODE=true node scripts/audit-api-routes.mjs",
    "audit:repo": "node scripts/audit-repo.mjs",
    "sanity:live": "node scripts/sanity-live.mjs",
    "agents:check": "node scripts/agents-ci.mjs",
    "preflight": "npm run agents:check && npm run typecheck && npm run test:run && npm run lint:ci && npm run audit:api && npm run audit:repo",
    "ci:enterprise": "cross-env-shell RC_MODE=true \"npm run agents:check && npm run typecheck && npm run test:run && npm run test:tenant && npm run lint && npm run build:enterprise\"",
    "ci:critical": "npm run ci:enterprise",
    "push:ok": "npm run ci:critical && node -e \"process.exit(require('child_process').execSync('git status --porcelain').toString().trim() ? 1 : 0)\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:check": "git config core.hooksPath"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@sanity/client": "^7.14.0",
    "@sanity/icons": "^3.7.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.47.6",
    "next": "15.5.10",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
