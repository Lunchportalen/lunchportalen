{
  "name": "lunchportalen",
  "private": true,
  "version": "1.0.0",
  "description": "Lunchportalen – Firmalunsj med kontroll, forutsigbarhet og bærekraft",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-singleton.mjs",
    "dev:rc": "cross-env RC_MODE=true node scripts/dev-singleton.mjs",
    "build": "node scripts/verify-control-coverage.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 next build",
    "build:enterprise": "cross-env RC_MODE=true npm run agents:check && cross-env RC_MODE=true npm run ci:platform-guards && cross-env RC_MODE=true npm run audit:api && cross-env RC_MODE=true npm run audit:repo && cross-env RC_MODE=true npm run check:admin-copy && cross-env RC_MODE=true npm run check:ai-internal-provider && cross-env RC_MODE=true node scripts/verify-control-coverage.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 RC_MODE=true next build && node scripts/seo-proof.mjs && node scripts/seo-audit.mjs && node scripts/seo-content-lint.mjs",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "next lint",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "verify:production-public-cms": "node scripts/verify-production-public-cms.mjs",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts --reporter=basic",
    "test:watch": "vitest --config vitest.config.ts",
    "test:tenant": "vitest run tests/tenant-isolation.test.ts --config vitest.config.ts",
    "test:rls": "vitest run tests/rls/tenantIsolation.final.test.ts --config vitest.config.ts",
    "test:db": "vitest run tests/db/database-integrity.test.ts --config vitest.config.ts",
    "db:rebuild-verify": "node scripts/ci/db-rebuild-verify.mjs",
    "db:types": "npx supabase gen types typescript --local -o lib/types/database.ts",
    "e2e": "playwright test --config playwright.config.ts",
    "e2e:ui": "playwright test --config playwright.config.ts --ui",
    "e2e:headed": "playwright test --config playwright.config.ts --headed",
    "e2e:update-snapshots": "playwright test --config playwright.config.ts --update-snapshots",
    "e2e:install": "playwright install --with-deps",
    "e2e:debug": "playwright test --config playwright.config.ts --debug",
    "check:admin-copy": "node scripts/check-admin-no-hardcoded-text.mjs",
    "check:ai-internal-provider": "node scripts/check-ai-internal-provider.mjs",
    "audit:api": "cross-env RC_MODE=true node scripts/audit-api-routes.mjs",
    "audit:repo": "node scripts/audit-repo.mjs",
    "audit:generate": "tsx scripts/generateAudit.ts",
    "audit:full": "tsx scripts/generateFullAudit.ts && tsx scripts/exportFlatAudit.ts && tsx scripts/exportPrioritizedTasks.ts",
    "audit:tasks": "tsx scripts/buildTasks.ts",
    "autonomous:fix": "tsx scripts/autoFix.ts",
    "autonomous:validate": "tsx scripts/validate.ts",
    "autonomous:run": "tsx scripts/runAutonomous.ts",
    "evolution:run": "tsx lib/evolution/run.ts",
    "verify:control-coverage": "node scripts/verify-control-coverage.mjs",
    "sanity:live": "node scripts/sanity-live.mjs",
    "agents:check": "node scripts/agents-ci.mjs",
    "ci:guard": "node scripts/ci-guard.mjs",
    "api:contract": "node scripts/ci/api-contract-enforcer.mjs",
    "status:guard": "node scripts/ci/status-code-guard.mjs",
    "mock:check": "node scripts/ci/mock-integrity.mjs",
    "cms:check": "node scripts/ci/cms-integrity.mjs",
    "ai:check": "node scripts/ci/ai-governance-check.mjs",
    "ui:clickable-check": "node scripts/ci/ui-clickable-div.mjs",
    "ci:platform-guards": "npm run api:contract && npm run status:guard && npm run mock:check && npm run cms:check && npm run ai:check && npm run ui:clickable-check",
    "preflight": "npm run ci:guard && npm run agents:check && npm run ci:platform-guards && npm run typecheck && npm run test:run && npm run lint && npm run audit:api",
    "ci:enterprise": "cross-env RC_MODE=true npm run ci:guard && cross-env RC_MODE=true npm run agents:check && cross-env RC_MODE=true npm run ci:platform-guards && cross-env RC_MODE=true npm run typecheck && cross-env RC_MODE=true npm run test:run && cross-env RC_MODE=true npm run test:tenant && cross-env RC_MODE=true npm run lint && cross-env RC_MODE=true npm run build:enterprise",
    "ci:critical": "npm run ci:enterprise",
    "push:ok": "npm run ci:critical && node -e \"process.exit(require('child_process').execSync('git status --porcelain').toString().trim() ? 1 : 0)\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:check": "git config core.hooksPath",
    "postdeploy": "node scripts/postdeploy.mjs",
    "seo:proof": "node scripts/seo-proof.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "seo:content-lint": "node scripts/seo-content-lint.mjs",
    "system:test": "tsx scripts/system-test/runner.ts",
    "test:social-flow": "tsx scripts/testSocialFlow.ts",
    "repo:scan": "tsx scripts/scanRepo.ts",
    "repo:update": "tsx scripts/updateRepoMemory.ts",
    "worker:queue": "tsx workers/worker.ts"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sanity/client": "^7.14.0",
    "@sanity/icons": "^3.7.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.47.6",
    "framer-motion": "^12.38.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "graphlib": "^2.1.8",
    "lucide-react": "^0.460.0",
    "ml-matrix": "^6.12.1",
    "next": "15.5.10",
    "nodemailer": "^7.0.13",
    "onnxruntime-node": "^1.24.3",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "reactflow": "^11.11.4",
    "redis": "^4.7.0",
    "regression": "^2.0.1",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "simple-statistics": "^7.8.9",
    "stripe": "^17.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@types/regression": "^2.0.6",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.4",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.10",
    "jsdom": "^29.0.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
