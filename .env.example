SYSTEM_MOTOR_SECRET=CHANGE_ME

# Integrations (optional; default off / safe)
ADS_ENABLED=false
EMAIL_ENABLED=false
TRIPLETEX_ENABLED=false
# Tripletex: see lib/integrations/tripletex/client.ts (TRIPLETEX_COMPANY_ID, TRIPLETEX_TOKEN or session tokens)
TRIPLETEX_REVENUE_DEFAULT_CUSTOMER_ID=
TRIPLETEX_REVENUE_DEFAULT_PRODUCT_ID=
TRIPLETEX_REVENUE_DEFAULT_VAT_CODE=


# Autonomous scaling cron (ROI → max 2 internal singularity actions; no direct spend)
SCALING_ENGINE_ENABLED=true


# Profit maximization cron (margin / leaks -> max 2 internal singularity actions; no payments)
PROFIT_ENGINE_ENABLED=true


# Persist opsLog rows to ai_observability (async, non-blocking; can increase DB write volume)
AI_OBSERVABILITY_PERSIST=true


# Realtime anomaly monitor cron (Slack/email throttled; requires migration ai_alerts)
MONITORING_ENABLED=true
SLACK_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=true


# --- Supabase (app / SSR) ---
# Public URL and publishable key for browser + cookie-based SSR (middleware refresh + server client).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallbacks during key migration (optional if PUBLISHABLE_KEY is set):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: server-only via lib/supabase/admin.ts — never expose to client or middleware.
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI migrations / db push use the database connection string (host + DB password), not NEXT_PUBLIC_* keys.
