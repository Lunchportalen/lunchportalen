# POST-DEPLOY (PROD) environment contract
# Required
POSTDEPLOY_BASE_URL=https://<DIN_PROD_URL>

# Optional: request timeout (ms)
# Default: 12000
POSTDEPLOY_TIMEOUT_MS=12000

# Optional: HTML/text routes to smoke-check (comma-separated)
# Default: "/,/login,/status,/system"
# POSTDEPLOY_ROUTES=/,/login,/status,/system

# Optional: JSON routes to smoke-check (comma-separated)
# Default: "/api/health,/api/system/health"
# POSTDEPLOY_JSON_ROUTES=/api/health,/api/system/health

# Optional: disable JSON checks
# Set to 0 to disable
# POSTDEPLOY_JSON_CHECKS=0

# Optional: text that must appear in HTML responses
# POSTDEPLOY_EXPECTED_TEXT=
