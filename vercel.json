{
  "crons": [
    {
      "path": "/api/cron/week-scheduler?key=${CRON_SECRET}",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/forecast?key=${CRON_SECRET}",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/preprod?key=${CRON_SECRET}",
      "schedule": "5 8 * * 1-5"
    }
  ],
  "ignoreCommand": "git diff --name-only HEAD^ HEAD | grep -q '^studio/' && ! git diff --name-only HEAD^ HEAD | grep -vq '^studio/'"
}