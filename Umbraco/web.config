<?xml version="1.0" encoding="utf-8"?>
<!-- IIS / Azure App Service (Windows): AspNetCoreModuleV2 stdout to %home%\LogFiles for Kudu/Diagnose. SDK publish preserves this template. -->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\Umbraco.dll" stdoutLogEnabled="true" stdoutLogFile="\\?\%home%\LogFiles\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
